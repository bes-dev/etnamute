{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep",
      "Agent",
      "mcp__mcpdoc__*",
      "mcp__stitch__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(fdisk *)",
      "Edit(//etc/**)",
      "Edit(//sys/**)",
      "Edit(//proc/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "mcpdoc",
    "stitch"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-syntax.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
