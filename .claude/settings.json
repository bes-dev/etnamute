{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(mkdir apps/*)",
      "Bash(cp apps/*)",
      "Bash(mv apps/*)",
      "Bash(rm apps/*)",
      "Bash(chmod *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(grep *)",
      "Bash(fastlane *)",
      "Bash(maestro *)",
      "Bash(cd /tmp *)",
      "Read(/tmp/**)",
      "Read(/private/tmp/**)",
      "WebSearch",
      "WebFetch(*)",
      "mcp__mcpdoc__*"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "mcpdoc"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-syntax.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
