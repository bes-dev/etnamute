{
  "mcpServers": {
    "mcpdoc": {
      "type": "stdio",
      "command": "mcpdoc",
      "args": [
        "--urls",
        "https://docs.expo.dev/llms.txt",
        "https://www.revenuecat.com/docs/llms.txt"
      ]
    },
    "stitch": {
      "type": "stdio",
      "command": "npx",
      "args": ["@_davideast/stitch-mcp", "proxy"],
      "env": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      }
    }
  }
}
